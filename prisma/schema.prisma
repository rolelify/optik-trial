generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Run {
  id          String   @id @default(uuid())
  url         String
  timestamp   DateTime @default(now())
  diffText    String?
  intentMode  Boolean  @default(true)
  status      String   @default("running") // pass, fail, warn, running
  error       String?

  mobileResult  Json?
  desktopResult Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
